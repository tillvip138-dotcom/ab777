<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>AB777 Admin Panel</title>
    <style>
        body { font-family: Arial, sans-serif; background: #1a1a1a; color: #fff; }
        .sidebar { width: 200px; height: 100vh; background: #333; float: left; padding: 20px; }
        .main-content { margin-left: 240px; padding: 20px; }
        .card { background: #444; padding: 15px; border-radius: 8px; margin-bottom: 20px; }
        .btn { background: #ffcc00; color: #000; padding: 10px 20px; border: none; cursor: pointer; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>AB777 Admin</h2>
        <ul>
            <li>Dashboard</li>
            <li>Users</li>
            <li>Deposits</li>
            <li>Withdrawals</li>
        </ul>
    </div>
    <div class="main-content">
        <h1>Admin Dashboard</h1>
        <div class="card">
            <h3>Total Users: 1,250</h3>
        </div>
        <div class="card">
            <h3>Pending Withdrawals: 15</h3>
            <button class="btn">Approve All</button>
        </div>
    </div>
</body>
</html>
